# Your Privy app ID. Must be registered in CC's PartnerApp table before
# tokens are accepted (coordinate with the CC team to add it).
NEXT_PUBLIC_PARTNER_PRIVY_APP_ID=

# CollectorCrypt backend URL.
# Prod:    https://api.collectorcrypt.com
# Staging: https://staging-api.collectorcrypt.com
# Dev:     https://dev-api.collectorcrypt.com
# Local:   http://localhost:5002
NEXT_PUBLIC_CC_API_URL=https://staging-api.collectorcrypt.com

# Optional. Used by the Section 5 "Find my CC NFTs" demo (Helius DAS
# searchAssets call). Without it, partners can still enter NFT addresses
# manually; this just lists what the user owns in CC's collections.
# Get one at https://helius.dev (free tier works).
NEXT_PUBLIC_HELIUS_API_KEY=
